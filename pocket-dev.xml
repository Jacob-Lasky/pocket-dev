<?xml version="1.0"?>
<Container version="2">
  <Name>pocket-dev</Name>
  <Repository>ghcr.io/jacob-lasky/pocket-dev:latest</Repository>
  <Registry>https://github.com/Jacob-Lasky/pocket-dev/pkgs/container/pocket-dev</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/Jacob-Lasky/pocket-dev/issues</Support>
  <Project>https://github.com/Jacob-Lasky/pocket-dev</Project>
  <ReadMe/>
  <Overview>Browser-accessible terminal for Claude Code, mobile-first. Spawns a tmux session running Claude under a restart loop and exposes it via xterm.js over WebSocket, so a desktop or phone can attach to the same session and survive disconnects.&#13;
&#13;
Click the WebUI button to open the terminal in your browser. Claude auto-starts; just begin typing.&#13;
&#13;
Authentication: provide ANTHROPIC_API_KEY or run 'claude login' once. Auth persists in the config volume.</Overview>
  <Category>Productivity: Tools: Development:</Category>
  <WebUI>http://[IP]:[PORT:7681]</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/Jacob-Lasky/pocket-dev/main/pocket-dev.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/Jacob-Lasky/pocket-dev/main/icon.png</Icon>
  <ExtraParams>--group-add 281</ExtraParams>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Requires/>
  <Config Name="WebUI Port" Target="7681" Default="7681" Mode="tcp" Description="Web terminal port (xterm.js over WebSocket)" Type="Port" Display="always" Required="true" Mask="false">7681</Config>
  <Config Name="ANTHROPIC_API_KEY" Target="ANTHROPIC_API_KEY" Default="" Mode="" Description="Optional: Your Anthropic API key. If not provided, run 'claude login' in the terminal on first use." Type="Variable" Display="always" Required="false" Mask="true"/>
  <Config Name="Workspace" Target="/workspace" Default="/mnt/user/appdata/claude-code/workspace" Mode="rw" Description="Directory where claude-code will work with your files" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/claude-code/workspace</Config>
  <Config Name="Claude Config" Target="/home/claude/.claude" Default="/mnt/user/appdata/claude-code/config" Mode="rw" Description="Claude configuration and settings directory" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/claude-code/config</Config>
  <Config Name="Claude JSON Config" Target="/home/claude/.claude.json" Default="/mnt/user/appdata/claude-code/claude.json" Mode="rw" Description="Persists MCP server configs and settings across container restarts" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/claude-code/claude.json</Config>
  <Config Name="Google Workspace Credentials" Target="/home/claude/.google_workspace_mcp" Default="/mnt/user/appdata/claude-code/google-workspace-mcp" Mode="rw" Description="Persists Google Workspace OAuth credentials across container restarts" Type="Path" Display="always" Required="false" Mask="false">/mnt/user/appdata/claude-code/google-workspace-mcp</Config>
  <Config Name="dgvpn State" Target="/home/claude/.dgvpn" Default="/mnt/user/appdata/claude-code/dgvpn" Mode="rw" Description="Persists the Deepgram tailnet (dgvpn) registration across container restarts so you re-auth only when the ~24h key expires, not on every recreate." Type="Path" Display="advanced" Required="false" Mask="false">/mnt/user/appdata/claude-code/dgvpn</Config>
  <Config Name="Docker Socket" Target="/var/run/docker.sock" Default="/var/run/docker.sock" Mode="ro" Description="Docker socket, read-only. Lets Claude inspect host containers (docker ps, docker logs, docker inspect) but NOT restart / stop / run — switch to rw if you want those." Type="Path" Display="always" Required="true" Mask="false">/var/run/docker.sock</Config>
  <Config Name="templates" Target="/templates" Default="" Mode="rw" Description="" Type="Path" Display="always" Required="false" Mask="false">/boot/config/plugins/dockerMan/templates-user/</Config>
  <Config Name="compose-files" Target="/compose" Default="" Mode="rw" Description="" Type="Path" Display="always" Required="false" Mask="false">/boot/config/plugins/compose.manager/projects/</Config>
  <Config Name="coding" Target="/coding" Default="" Mode="rw" Description="" Type="Path" Display="always" Required="false" Mask="false">/mnt/user/misc/coding</Config>
  <Config Name="settings json" Target="/home/claude/.settings.json" Default="" Mode="rw" Description="" Type="Path" Display="always" Required="false" Mask="false">/mnt/user/appdata/claude-code/settings.json</Config>
  <Config Name="data" Target="/data" Default="" Mode="rw" Description="" Type="Path" Display="always" Required="false" Mask="false">/mnt/user/data</Config>
  <Config Name="PUID" Target="PUID" Default="99" Mode="" Description="User ID (default: 99 for Unraid)" Type="Variable" Display="advanced" Required="false" Mask="false">99</Config>
  <Config Name="PGID" Target="PGID" Default="100" Mode="" Description="Group ID (default: 100 for Unraid)" Type="Variable" Display="advanced" Required="false" Mask="false">100</Config>
  <TailscaleStateDir/>
</Container>
